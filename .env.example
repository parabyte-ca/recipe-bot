# ── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram — notifications (existing bot) ───────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Telegram — recipe input bot (NEW — separate bot from BotFather) ───────────
TELEGRAM_RECIPE_BOT_TOKEN=
# Comma-separated chat IDs allowed to submit recipes (leave blank = allow all)
TELEGRAM_ALLOWED_CHATS=

# ── WordPress ─────────────────────────────────────────────────────────────────
WP_URL=http://wordpress
WP_USER=admin
# Generate in WP Admin: Users > Profile > Application Passwords
WP_APP_PASSWORD=

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=change_me_strong_password
DB_ROOT_PASSWORD=change_me_root_password

# ── Paths (host-side, SMB accessible) ────────────────────────────────────────
INPUT_HOST_DIR=/mnt/shared_vol/home/amoote/recipe-bot/input
OUTPUT_HOST_DIR=/mnt/shared_vol/home/amoote/recipe-bot/output

# ── Internal container paths (do not change) ─────────────────────────────────
INPUT_DIR=/data/input
OUTPUT_DIR=/data/output
URL_LIST=/data/input/urls.txt

# ── Crawl schedule (cron, default 08:00 daily) ───────────────────────────────
CRAWL_CRON=0 8 * * *
